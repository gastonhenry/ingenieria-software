<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <appSettings>
        <!-- Credenciales locales de mantenimiento (break-glass).
             Sólo se usan cuando la verificación de integridad falla y el usuario es 'admin'.
             Para rotar la pass: ejecutar PasswordHasher.GenerateSalt() + HashPassword(nuevaPass, salt)
             y reemplazar ambos valores. Default: usuario=admin pass=Maint2026! -->
        <add key="MaintenanceAdminUser" value="admin" />
        <add key="MaintenanceAdminSalt" value="BmMxoziKUCOKR1xPkMNYvQ==" />
        <add key="MaintenanceAdminHash" value="48c1b050d77336c52e39a13872f714c70a488e96b4d5b3fc7a50726659cb1cac" />

        <!-- Carpeta donde se guardan / leen los .bak para Backup/Restore. -->
        <add key="BackupFolder" value="C:\Backups\Ingenieria" />
    </appSettings>
</configuration>
